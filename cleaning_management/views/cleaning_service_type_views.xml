<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Window action for Service Type -->
    <record id="cleaning_service_type_action" model="ir.actions.act_window">
        <field name="name">Service Type</field>
        <field name="res_model">cleaning.service.type</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
               Create a New Service Type
             </p>
        </field>
    </record>

    <!-- Service Type form view -->
    <record id="cleaning_service_type_view_form" model="ir.ui.view">
        <field name="name">cleaning.service.type.view.form</field>
        <field name="model">cleaning.service.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="facility_type_id" options="{'no_create': True, 'no_open': True}"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Service Type tree view -->
    <record id="cleaning_service_type_view_tree" model="ir.ui.view">
        <field name="name">cleaning.service.type.view.tree</field>
        <field name="model">cleaning.service.type</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="facility_type_id"/>
            </tree>
        </field>
    </record>
</odoo>
